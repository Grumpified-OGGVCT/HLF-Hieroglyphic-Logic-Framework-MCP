# Verified Developer KB Pro - Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# REQUIRED: Google AI Services
# =============================================================================

# Your Google Gemini API key
GOOGLE_API_KEY=your-gemini-api-key-here

# Google Cloud project ID (for File Search)
GOOGLE_CLOUD_PROJECT=your-project-id

# Google File Search store ID (created in Google Cloud Console)
FILE_SEARCH_STORE_ID=your-store-id

# =============================================================================
# DATABASE (PostgreSQL with pgvector)
# =============================================================================

# For local development with Docker Compose:
DATABASE_URL=postgresql://kbpro:password@localhost:5432/kbpro

# For Railway (they provide this automatically):
# DATABASE_URL=postgresql://...@....railway.app:5432/railway

# =============================================================================
# REDIS (for caching)
# =============================================================================

# For local development:
REDIS_URL=redis://localhost:6379

# For Railway:
# REDIS_URL=redis://default:...@....railway.app:6379

# =============================================================================
# OPTIONAL: Fallback Services
# =============================================================================

# Anthropic API key for Claude Haiku fallback (optional)
ANTHROPIC_API_KEY=

# Qdrant URL for local vector DB fallback (optional)
QDRANT_URL=http://localhost:6333

# Enable/disable fallback chain
FALLBACK_ENABLED=true

# =============================================================================
# OPENROUTER (Multi-Provider LLM Access - 300+ Models)
# =============================================================================

# OpenRouter API key (get one at https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# Default model for OpenRouter requests
# Options: anthropic/claude-3.5-sonnet, openai/gpt-4o, meta-llama/llama-3.1-70b-instruct
OPENROUTER_DEFAULT_MODEL=anthropic/claude-3.5-sonnet

# Routing sort: price (cheapest), throughput (fastest), latency (lowest TTFT)
OPENROUTER_SORT=price

# Data collection policy: allow (default), deny (privacy-first)
OPENROUTER_DATA_COLLECTION=deny

# Zero Data Retention: true to only use ZDR endpoints
OPENROUTER_ZDR=false

# Maximum price per million tokens (cost control)
OPENROUTER_MAX_PRICE_PROMPT=5.0
OPENROUTER_MAX_PRICE_COMPLETION=15.0

# App attribution for OpenRouter rankings
OPENROUTER_APP_NAME=Verified Developer KB Pro
OPENROUTER_APP_URL=

# =============================================================================
# OLLAMA (Cloud + Local)  — Admin-controlled provider (NOT user-facing)
# =============================================================================
# Default to the local Ollama server. Use https://ollama.com/api only as backup.
# Docs: https://docs.ollama.com/api/introduction
OLLAMA_BASE_URL=http://localhost:11434/api

# Required for ollama.com cloud API access (not required for local):
# Docs: https://docs.ollama.com/api/authentication
OLLAMA_API_KEY=

# =============================================================================
# MODEL POLICY (Admin-only) — Provider/model selection chains
# =============================================================================
# These settings control which models are used internally. End users never choose.
#
# Cloud model catalog reference (what's marked "cloud" in the library):
# https://ollama.com/search?c=cloud&o=newest
#
# RTD / grounded general: prefer Ollama Cloud Gemini 3 Flash Preview
MODEL_RTD_PRIMARY_PROVIDER=ollama
MODEL_RTD_PRIMARY_MODEL=gemini-3-flash-preview
MODEL_RTD_PRIMARY_MODEL_ALIASES=gemini-3-flash-preview,gemini-3-flash

# RTD fallback chain:
# - OpenRouter fallback model ID (admin must set; leave empty to disable)
MODEL_RTD_FALLBACK_OPENROUTER_MODEL=
# - Gemini direct fallback model name (admin must set; leave empty to use GEMINI_RESEARCH_MODEL_NAME or GEMINI_MODEL_NAME)
MODEL_RTD_FALLBACK_GEMINI_MODEL=

# Strong reasoning (non-RTD): prefer Ollama Cloud GLM-4.7
MODEL_REASONER_PRIMARY_PROVIDER=ollama
MODEL_REASONER_PRIMARY_MODEL=glm-4.7
MODEL_REASONER_FALLBACK_OPENROUTER_MODEL=

# Final QA pass (secondary critique): enabled by default
MODEL_QA_ENABLED=true
MODEL_QA_PROVIDER=ollama
MODEL_QA_MODEL=glm-4.7

# Avoid premium / limited models by default (e.g., Gemini 3 Pro Preview)
MODEL_DISALLOW_PREMIUM_MODELS=true
MODEL_PREMIUM_MODELS=gemini-3-pro-preview

# =============================================================================
# LLM ROUTING STRATEGY
# =============================================================================

# Routing strategy for LLM requests:
#   primary_only    - Use Ollama exclusively (fail if unavailable)
#   fallback        - Try Ollama, fall back to OpenRouter on failure (RECOMMENDED)
#   openrouter_only - Use OpenRouter exclusively
#   cost_optimized  - Route to cheapest option
#   throughput      - Route to fastest option
#   privacy_first   - Use only ZDR endpoints via OpenRouter
LLM_ROUTING_STRATEGY=fallback

# Primary provider: ollama or openrouter
LLM_PRIMARY_PROVIDER=ollama

# Enable fallback to secondary provider
LLM_FALLBACK_ENABLED=true

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Environment: development, staging, production
ENVIRONMENT=development

# Debug mode (enables verbose logging)
DEBUG=false

# =============================================================================
# PATHS
# =============================================================================

# Knowledge base file paths
KB_FILES_PATH=./kb_files
KB_STAGING_PATH=./kb_staging
STACK_PACKS_PATH=./stack_packs
LOCKS_PATH=./locks
ALERTS_PATH=./alerts

# =============================================================================
# KB MODEL CONFIGURATION
# =============================================================================

# Confidence threshold for hits (0.0 - 1.0)
CONFIDENCE_THRESHOLD=0.80

# Monthly confidence decay rate (0.95 = 5% decay per month)
CONFIDENCE_DECAY_RATE=0.95

# Gemini model names
GEMINI_MODEL_NAME=gemini-1.5-pro
GEMINI_RESEARCH_MODEL_NAME=gemini-1.5-pro
GEMINI_EMBEDDING_MODEL=models/embedding-001

# =============================================================================
# WORKER CONFIGURATION
# =============================================================================

# Worker identifier (auto-generated if not set)
WORKER_ID=

# Heartbeat interval in seconds
WORKER_HEARTBEAT_INTERVAL=30

# Max retries before moving to DLQ
WORKER_MAX_RETRIES=3

# Consecutive failures before emergency stop
EMERGENCY_STOP_THRESHOLD=5

# Queue poll interval in seconds
WORKER_POLL_INTERVAL=5

# =============================================================================
# CIRCUIT BREAKER
# =============================================================================

# Failures before circuit opens
CIRCUIT_BREAKER_FAIL_MAX=3

# Seconds before circuit resets
CIRCUIT_BREAKER_RESET_TIMEOUT=300

# =============================================================================
# MONITORING
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Log format: json or console
LOG_FORMAT=console

# Prometheus metrics port
PROMETHEUS_PORT=9090

# =============================================================================
# SECURITY
# =============================================================================

# Secret key for signing (generate with: openssl rand -hex 32)
SECRET_KEY=change-me-in-production

# Allowed CORS origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000


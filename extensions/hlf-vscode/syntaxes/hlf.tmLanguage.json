{
  "name": "HLF",
  "scopeName": "source.hlf",
  "fileTypes": ["hlf"],
  "patterns": [
    {"include": "#comment"},
    {"include": "#version_header"},
    {"include": "#block"},
    {"include": "#terminator"},
    {"include": "#line_glyph"},
    {"include": "#glyph"},
    {"include": "#ascii_alias"},
    {"include": "#canonical_tag"},
    {"include": "#i18n_latin_tag"},
    {"include": "#i18n_cjk_tag"},
    {"include": "#i18n_arabic_tag"},
    {"include": "#generic_tag"},
    {"include": "#string"},
    {"include": "#variable"},
    {"include": "#control_keyword"},
    {"include": "#definition_keyword"},
    {"include": "#declaration_keyword"},
    {"include": "#spec_keyword"},
    {"include": "#builtin_keyword"},
    {"include": "#logical_keyword"},
    {"include": "#boolean"},
    {"include": "#typed_param"},
    {"include": "#property_key"},
    {"include": "#path"},
    {"include": "#number"},
    {"include": "#comparison_operator"},
    {"include": "#arithmetic_operator"},
    {"include": "#assignment_operator"},
    {"include": "#punctuation"},
    {"include": "#identifier"}
  ],
  "repository": {
    "comment": {
      "match": "#.*$",
      "name": "comment.line.number-sign.hlf"
    },
    "version_header": {
      "match": "\\[HLF-v\\d+(?:\\.\\d+)*\\]",
      "name": "keyword.control.version.hlf"
    },
    "block": {
      "begin": "\\{",
      "beginCaptures": {
        "0": {"name": "punctuation.definition.block.begin.hlf"}
      },
      "end": "\\}",
      "endCaptures": {
        "0": {"name": "punctuation.definition.block.end.hlf"}
      },
      "name": "meta.block.hlf",
      "patterns": [
        {"include": "$self"}
      ]
    },
    "terminator": {
      "match": "\u03a9|\\b(?:Omega|OMEGA|END)\\b",
      "name": "keyword.operator.terminator.hlf"
    },
    "line_glyph": {
      "match": "^\\s*[\u0394\u0416\u2a1d\u2318\u2207\u2a55\u228e]",
      "name": "keyword.control.command.hlf"
    },
    "glyph": {
      "match": "[\u0394\u0416\u2a1d\u2318\u2207\u2a55\u228e]",
      "name": "keyword.operator.glyph.hlf"
    },
    "ascii_alias": {
      "match": "\\b(?:ANALYZE|ANALYSE|ANALYSER|ANALIZAR|ENFORCE|CONSTRAIN|JOIN|CONSENSUS|VOTE|CMD|COMMAND|DELEGATE|SOURCE|PARAM|PRIORITY|BRANCH|UNION|DELTA|ZHE)\\b",
      "name": "support.constant.alias.hlf"
    },
    "canonical_tag": {
      "match": "\\[(?:ACTION|AGREE|ALIGN|ARG|ARGUMENT|ASSERT|ASSERTION|ASSIGN_TO|CHECK|CONFIG|CONSENSUS|CONSTRAINT|DATA_SOURCE|DEFINE|DELEGATE|DELEGATION|DISPATCH|EXPECT|EXPECTED|FORWARD|FROM|GATE|GOAL|HANDOFF|IMPORTANCE|INPUT|INTENT|INTENTION|LOOKUP|MEMORIZE|MEMORY|MIGRATION|MIGRATION_SPEC|MODULE|OBSERVATION|OUTPUT|OUTPUT_TYPE|PARAM|PARAMETER|PLAN|PRECONDITION|PRIORITY|QUERY|QUORUM|RANK|RECALL|REMEMBER|RESPONSE|RESTRICT|RESTRICTION|RESULT|RETRIEVE|RETURN|ROUTE|ROUTING|SET|SOURCE|STORE|THOUGHT|URGENCY|VOTE|WEIGHT)\\]",
      "name": "entity.name.tag.hlf"
    },
    "i18n_latin_tag": {
      "match": "\\[(?:ABFRAGEN|ABRUFEN|ABSICHT|ABSTIMMEN|ACCORD|ACHEMINER|ACUERDO|AFIRMACAO|AFIRMACION|AFFIRMER|ALMACENAR|ANTWORT|ARGUMENTO|ARMAZENAR|ASIGNAR_A|ATRIBUIR|ATTENDRE|ATTENDU|AUSGABE|AUSGABETYP|BEDINGUNG|BEHAUPTUNG|BESCHRAENKUNG|BUSCAR|BUT|CHERCHER|CONDICAO|CONFIER|CONFIGURACAO|CONFIGURACION|CONFIGURATION|CONSENSO|CONSTRENIMIENTO|CONSULTAR|CONTRAINTE|DATENQUELLE|DELEGACAO|DELEGACION|DELEGIEREN|DELEGUER|DELEGAR|DESDE|DESPACHAR|DISTRIBUER|DRINGLICHKEIT|EINGABE|EINIGUNG|EINSCHRAENKUNG|ENCAMINHAR|ENRUTAR|ENRUTAMIENTO|ENTRADA|ERGEBNIS|ERINNERN|ERWARTET|ERWARTEN|ESPERAR|ESPERADO|FONTE|FUENTE|GEDAECHTNIS|GEWICHT|IMPORTANCIA|INTENCAO|INTENCION|INTERROGER|KONFIGURATION|KONSENS|LEMBRAR|LIMITACAO|LIMITACION|LIMITE|MEMOIRE|MEMORIEREN|MEMORISER|MEMORIZAR|META|OBJETIVO|OBJECTIF|OBTENER|ORIGEN|ORIGEM|PARAMETRO|PARAMETRE|PESO|POIDS|PRECONDICION|PRECONDICAO|PRIORITAET|PRIORIDAD|PRIORIDADE|PRIORITE|PROVENANCE|PRUEFEN|QUELLE|RANG|RANGO|RAPPELER|RECORDAR|RECUPERAR|RECUPERER|REPONSE|RESPOSTA|RESPUESTA|RESTRICAO|RESTRICCION|RESULTAT|RESULTAT_ATTENDU|RESULTADO|RETORNAR|RETOURNER|ROTEAMENTO|ROTEAR|ROUTEN|ROUTAGE|RUECKGABE|SAIDA|SALIDA|SE_SOUVENIR|SORTIE|SPEICHERN|STOCKER|SUCHEN|TIPO_SAIDA|TIPO_SALIDA|TRANSFERER|TRANSMETTRE|UEBERGEBEN|URGENCE|URGENCIA|VERIFICACAO|VERIFICACION|VERIFICATION|VERTEILEN|VON|VORHABEN|VORBEDINGUNG|VOTER|VOTAR|WEITERLEITEN|WICHTIGKEIT|WIEDERFINDEN|ZIEL|ZURUECKRUFEN|ZUWEISEN)\\]",
      "name": "entity.name.tag.i18n.hlf"
    },
    "i18n_cjk_tag": {
      "match": "\\[(?:\u610f\u56fe|\u76ee\u6807|\u76ee\u7684|\u7ea6\u675f|\u9650\u5236|\u7ea6\u675f\u6761\u4ef6|\u65ad\u8a00|\u524d\u7f6e\u6761\u4ef6|\u68c0\u67e5|\u671f\u671b|\u9884\u671f|\u671f\u5f85|\u59d4\u6258|\u59d4\u6d3e|\u4ee3\u7406|\u8f6c\u4ea4|\u8def\u7531|\u5206\u53d1|\u8f6c\u53d1|\u8c03\u5ea6|\u6765\u6e90|\u8f93\u5165|\u6570\u636e\u6e90|\u4ece|\u53c2\u6570|\u914d\u7f6e|\u914d\u7f6e\u9879|\u4f18\u5148\u7ea7|\u7d27\u6025\u5ea6|\u6743\u91cd|\u91cd\u8981\u6027|\u6295\u7968|\u5171\u8bc6|\u6cd5\u5b9a\u4eba\u6570|\u540c\u610f|\u7ed3\u679c|\u8fd4\u56de|\u8f93\u51fa|\u54cd\u5e94|\u8bb0\u5fc6|\u5b58\u50a8|\u8bb0\u4f4f|\u8bb0\u5fc6\u5316|\u53ec\u56de|\u68c0\u7d22|\u67e5\u627e|\u67e5\u8be2|\u610f\u56f3|\u5236\u7d04|\u5236\u9650|\u5236\u7d04\u6761\u4ef6|\u30a2\u30b5\u30fc\u30b7\u30e7\u30f3|\u524d\u63d0\u6761\u4ef6|\u78ba\u8a8d|\u4e88\u671f|\u671f\u5f85\u5024|\u59d4\u8b72|\u30c7\u30ea\u30b2\u30fc\u30c8|\u59d4\u4efb|\u5f15\u304d\u6e21\u3057|\u30eb\u30fc\u30c6\u30a3\u30f3\u30b0|\u30eb\u30fc\u30c8|\u8ee2\u9001|\u30c7\u30a3\u30b9\u30d1\u30c3\u30c1|\u30bd\u30fc\u30b9|\u30c7\u30fc\u30bf\u30bd\u30fc\u30b9|\u304b\u3089|\u30d1\u30e9\u30e1\u30fc\u30bf|\u5f15\u6570|\u8a2d\u5b9a|\u512a\u5148\u5ea6|\u7dca\u6025\u5ea6|\u91cd\u307f|\u30b3\u30f3\u30bb\u30f3\u30b5\u30b9|\u5408\u610f|\u5b9a\u8db3\u6570|\u8fd4\u5374|\u51fa\u529b|\u30ec\u30b9\u30dd\u30f3\u30b9|\u30e1\u30e2\u30ea|\u8a18\u61b6|\u8a18\u9332|\u8a18\u61b6\u3059\u308b|\u547c\u3073\u51fa\u3059|\u53d6\u5f97|\u691c\u7d22|\u60f3\u8d77|\u30af\u30a8\u30ea)\\]",
      "name": "entity.name.tag.i18n.hlf"
    },
    "i18n_arabic_tag": {
      "match": "\\[(?:\u0646\u064a\u0629|\u0647\u062f\u0641|\u063a\u0627\u064a\u0629|\u0642\u064a\u062f|\u062a\u0642\u064a\u064a\u062f|\u0642\u064a\u0648\u062f|\u062a\u0623\u0643\u064a\u062f|\u0634\u0631\u0637 \u0645\u0633\u0628\u0642|\u0641\u062d\u0635|\u062a\u0648\u0642\u0639|\u0645\u062a\u0648\u0642\u0639|\u0646\u0648\u0639_\u0627\u0644\u0625\u062e\u0631\u0627\u062c|\u062a\u0641\u0648\u064a\u0636|\u062a\u0641\u0648\u064a\u0636_\u0645\u0647\u0645\u0629|\u0625\u0633\u0646\u0627\u062f|\u062a\u0648\u062c\u064a\u0647|\u062a\u0645\u0631\u064a\u0631|\u0625\u0631\u0633\u0627\u0644|\u0645\u0635\u062f\u0631|\u0625\u062f\u062e\u0627\u0644|\u0628\u064a\u0627\u0646\u0627\u062a_\u0645\u0635\u062f\u0631|\u0645\u0639\u0627\u0645\u0644|\u0648\u0633\u064a\u0637\u0629|\u062a\u0647\u064a\u0626\u0629|\u0623\u0648\u0644\u0648\u064a\u0629|\u0625\u0644\u062d\u0627\u062d|\u0648\u0632\u0646|\u0623\u0647\u0645\u064a\u0629|\u062a\u0635\u0648\u064a\u062a|\u062a\u0648\u0627\u0641\u0642|\u0646\u0635\u0627\u0628|\u0645\u0648\u0627\u0641\u0642\u0629|\u0646\u062a\u064a\u062c\u0629|\u0625\u0631\u062c\u0627\u0639|\u0625\u062e\u0631\u0627\u062c|\u0627\u0633\u062a\u062c\u0627\u0628\u0629|\u0630\u0627\u0643\u0631\u0629|\u062a\u062e\u0632\u064a\u0646|\u062a\u0630\u0643\u0631|\u062d\u0641\u0638|\u0627\u0633\u062a\u0631\u062c\u0627\u0639|\u0627\u0633\u062a\u0630\u0643\u0627\u0631|\u0628\u062d\u062b|\u0627\u0633\u062a\u0639\u0644\u0627\u0645)\\]",
      "name": "entity.name.tag.i18n.hlf"
    },
    "generic_tag": {
      "match": "\\[[A-Z][A-Z0-9_]*\\]",
      "name": "entity.name.tag.unregistered.hlf"
    },
    "string": {
      "begin": "\"",
      "beginCaptures": {
        "0": {"name": "punctuation.definition.string.begin.hlf"}
      },
      "end": "\"",
      "endCaptures": {
        "0": {"name": "punctuation.definition.string.end.hlf"}
      },
      "name": "string.quoted.double.hlf",
      "patterns": [
        {"include": "#escape"},
        {"include": "#string_variable"}
      ]
    },
    "escape": {
      "match": "\\\\.",
      "name": "constant.character.escape.hlf"
    },
    "string_variable": {
      "match": "\\$[A-Za-z_][A-Za-z0-9_]*|\\$\\{[A-Za-z_][A-Za-z0-9_]*\\}",
      "name": "variable.other.interpolated.hlf"
    },
    "variable": {
      "match": "\\$[A-Za-z_][A-Za-z0-9_]*|\\$\\{[A-Za-z_][A-Za-z0-9_]*\\}",
      "name": "variable.other.hlf"
    },
    "control_keyword": {
      "match": "\\b(?:IF|ELIF|ELSE|ENDIF|FOR|IN|PARALLEL)\\b",
      "name": "keyword.control.flow.hlf"
    },
    "definition_keyword": {
      "match": "\\b(?:FUNCTION|INTENT)\\b",
      "name": "keyword.control.definition.hlf"
    },
    "declaration_keyword": {
      "match": "\\b(?:SET|ASSIGN)\\b",
      "name": "storage.type.hlf"
    },
    "spec_keyword": {
      "match": "\\b(?:SPEC_DEFINE|SPEC_GATE|SPEC_UPDATE|SPEC_SEAL)\\b",
      "name": "keyword.other.spec.hlf"
    },
    "builtin_keyword": {
      "match": "\\b(?:CALL|TOOL|IMPORT|LOG|RETURN|MEMORY|RECALL|RESULT|ROUTE|DELEGATE)\\b",
      "name": "support.function.hlf"
    },
    "logical_keyword": {
      "match": "\\b(?:AND|OR|NOT)\\b",
      "name": "keyword.operator.logical.hlf"
    },
    "boolean": {
      "match": "\\b(?:true|false)\\b",
      "name": "constant.language.boolean.hlf"
    },
    "typed_param": {
      "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)(:)([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "captures": {
        "1": {"name": "variable.parameter.hlf"},
        "2": {"name": "punctuation.separator.type.hlf"},
        "3": {"name": "support.type.hlf"}
      }
    },
    "property_key": {
      "match": "\\b[a-z_][a-zA-Z0-9_]*(?=\\s*=)",
      "name": "variable.parameter.key.hlf"
    },
    "path": {
      "match": "(?:(?<=\\s)|^)/(?:[^\\s\\[\\]\"#{}()]|\\\\ )+",
      "name": "string.unquoted.path.hlf"
    },
    "number": {
      "match": "\\b\\d+(?:\\.\\d+)?\\b",
      "name": "constant.numeric.hlf"
    },
    "comparison_operator": {
      "match": "==|!=|<=|>=|<|>",
      "name": "keyword.operator.comparison.hlf"
    },
    "arithmetic_operator": {
      "match": "[-+*/%]",
      "name": "keyword.operator.arithmetic.hlf"
    },
    "assignment_operator": {
      "match": "=",
      "name": "keyword.operator.assignment.hlf"
    },
    "punctuation": {
      "patterns": [
        {"match": "\\(", "name": "punctuation.section.parens.begin.hlf"},
        {"match": "\\)", "name": "punctuation.section.parens.end.hlf"}
      ]
    },
    "identifier": {
      "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b",
      "name": "variable.other.readwrite.hlf"
    }
  }
}
